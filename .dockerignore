# Keep the build context (and image) small and the build deterministic.
venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.git/
.gitignore

# Node build artifacts — the frontend is built fresh inside the image.
frontend/node_modules/
frontend/dist/

# The full engine DB and caches are NOT needed at runtime (we ship
# deploy/serving.db only). Exclude the large file from the build context.
data/
notebooks/
tests/

.env
.DS_Store
